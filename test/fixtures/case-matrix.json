{
  "version": "1.2.0",
  "platformSets": {
    "ALL": [
      "node22-ubuntu",
      "node22-windows",
      "node22-macos",
      "node24-ubuntu",
      "node24-windows",
      "node24-macos"
    ],
    "POSIX_AND_WINDOWS": ["ubuntu", "windows", "macos"]
  },
  "limits": {
    "artifactBytes": 1048576,
    "jsonDepth": 64,
    "projectArtifacts": 10000,
    "circuitEdges": 10000,
    "jsonlLineBytes": 262144,
    "traceBytes": 67108864,
    "traceEvents": 100000
  },
  "mustHave": [
    {
      "id": "I01",
      "phase": "T007",
      "rule": "init.path-exists",
      "variants": ["manifest", "catalog-directory", "concurrent-process"],
      "platforms": "ALL",
      "mode": "native"
    },
    {
      "id": "I02",
      "phase": "T007",
      "rule": "init.cleanup-incomplete",
      "variants": ["non-empty-entry", "identity-changed-entry"],
      "platforms": "ALL",
      "mode": "native"
    },
    {
      "id": "I03",
      "phase": "T007",
      "variants": [
        "every-checkpoint-fault",
        "pre-capture-pending",
        "post-preflight-process-race",
        "exact-manifest-bytes",
        "exact-id-transform",
        "network-process-trap"
      ],
      "platforms": "ALL",
      "mode": "behavior"
    },
    {
      "id": "P01-artifact",
      "phase": "T006",
      "rule": "parse.invalid-utf8",
      "variants": ["artifact"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "P01-event",
      "phase": "T008",
      "rule": "parse.invalid-utf8",
      "variants": ["jsonl-event"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "P02",
      "phase": "T006",
      "rule": "parse.json-syntax",
      "variants": ["comment", "trailing-comma", "truncated-jsonl-object"],
      "platforms": "ALL",
      "mode": "file"
    },
    {
      "id": "P03",
      "phase": "T006",
      "rule": "parse.duplicate-key",
      "variants": ["permission-key"],
      "platforms": "ALL",
      "mode": "file"
    },
    {
      "id": "D01",
      "phase": "T006",
      "variants": ["missing", "non-string", "unsupported"],
      "platforms": "ALL",
      "mode": "generated",
      "rules": [
        "dispatch.api-version.required",
        "dispatch.api-version.type",
        "dispatch.api-version.unsupported"
      ]
    },
    {
      "id": "D02",
      "phase": "T006",
      "variants": ["missing", "non-string", "Rail"],
      "platforms": "ALL",
      "mode": "generated",
      "rules": ["dispatch.kind.required", "dispatch.kind.type", "dispatch.kind.unsupported"]
    },
    {
      "id": "D03",
      "phase": "T008",
      "variants": ["missing", "non-string", "unsupported"],
      "platforms": "ALL",
      "mode": "generated",
      "rules": [
        "dispatch.event-version.required",
        "dispatch.event-version.type",
        "dispatch.event-version.unsupported"
      ]
    },
    {
      "id": "S01",
      "phase": "T005",
      "rule": "schema.additional-property",
      "variants": ["every-object-boundary"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "S02",
      "phase": "T005",
      "variants": ["remote-ref", "unknown-keyword"],
      "platforms": "ALL",
      "mode": "generated",
      "rules": ["schema-registry.remote-ref", "schema-registry.unknown-keyword"]
    },
    {
      "id": "R01",
      "phase": "T006",
      "rule": "reference.not-found",
      "variants": [
        "project-artifact",
        "default-circuit",
        "module",
        "node",
        "port",
        "work-packet",
        "dependency",
        "fanout",
        "join"
      ],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "R02",
      "phase": "T006",
      "rule": "reference.kind-mismatch",
      "variants": ["artifact-envelope"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "R03",
      "phase": "T006",
      "rule": "reference.duplicate-identity",
      "variants": ["same-kind"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "G01",
      "phase": "T006",
      "rule": "graph.outcome-undeclared",
      "variants": ["route-outcome"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "G02",
      "phase": "T006",
      "rule": "graph.unsafe-cycle",
      "variants": ["self-loop", "multi-node-cycle"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "G03",
      "phase": "T006",
      "rule": "graph.ambiguous-fan-in",
      "variants": ["missing-join", "source-mismatch"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "G04",
      "phase": "T006",
      "variants": ["fanout-owner", "work-packet", "stop-condition"],
      "platforms": "ALL",
      "mode": "generated",
      "rules": ["graph.owner-required", "graph.stop-required"]
    },
    {
      "id": "G05",
      "phase": "T006",
      "variants": ["missing-port", "type-mismatch"],
      "platforms": "ALL",
      "mode": "generated",
      "rules": ["reference.port-not-found", "graph.transfer-type-mismatch"]
    },
    {
      "id": "T01",
      "phase": "T008",
      "variants": ["duplicate", "regression"],
      "platforms": "ALL",
      "mode": "generated",
      "rules": ["trace.sequence.duplicate", "trace.sequence.regression"]
    },
    {
      "id": "T02",
      "phase": "T008",
      "rule": "trace.duplicate-event-id",
      "variants": ["duplicate"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "T03",
      "phase": "T008",
      "variants": ["missing", "forward", "cross-run"],
      "platforms": "ALL",
      "mode": "generated",
      "rules": ["trace.cause.not-found", "trace.cause.forward", "trace.cause.cross-run"]
    },
    {
      "id": "T04",
      "phase": "T008",
      "rule": "trace.illegal-transition",
      "variants": [
        "queued-to-queued",
        "queued-to-input_required",
        "queued-to-completed",
        "queued-to-failed",
        "queued-to-timed_out",
        "running-to-queued",
        "running-to-running",
        "input_required-to-queued",
        "input_required-to-input_required",
        "input_required-to-completed",
        "input_required-to-failed"
      ],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "T05",
      "phase": "T008",
      "rule": "trace.terminal-immutable",
      "variants": ["completed", "failed", "cancelled", "timed_out"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "T06",
      "phase": "T008",
      "variants": ["missing-link", "not-queued"],
      "platforms": "ALL",
      "mode": "generated",
      "rules": ["trace.retry.link-required", "trace.retry.must-start-queued"]
    },
    {
      "id": "T07",
      "phase": "T008",
      "rule": "trace.event-not-allowed-in-state",
      "variants": ["heartbeat", "cancellation-request"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "T08",
      "phase": "T008",
      "rule": "trace.attempt.identity-conflict",
      "variants": ["metadata-change", "duplicate-work-packet-number"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "T09",
      "phase": "T008",
      "rule": "trace.retry.lineage-invalid",
      "variants": ["wrong-predecessor", "completed-parent", "forked-successor"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "T10",
      "phase": "T008",
      "rule": "trace.attempt.not-found",
      "variants": ["heartbeat", "outcome", "evidence"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "T11",
      "phase": "T008",
      "rule": "trace.attempt.must-start-queued",
      "variants": ["non-retry"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "T12",
      "phase": "T008",
      "variants": [
        "empty-file",
        "single-final-lf",
        "single-final-crlf",
        "repeated-final-lf",
        "repeated-final-crlf"
      ],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "T13",
      "phase": "T008",
      "rule": "schema.constraint",
      "variants": ["command-at-limit", "command-over-limit", "test-at-limit", "test-over-limit"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "T14",
      "phase": "T008",
      "variants": [
        "queued-to-running",
        "queued-to-cancelled",
        "running-to-input_required",
        "running-to-completed",
        "running-to-failed",
        "running-to-cancelled",
        "running-to-timed_out",
        "input_required-to-running",
        "input_required-to-cancelled",
        "input_required-to-timed_out"
      ],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "T15",
      "phase": "T008",
      "variants": ["failed-handoff"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "X01",
      "phase": "T006",
      "rule": "path.lexical-escape",
      "variants": ["parent-segment"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "X02",
      "phase": "T006",
      "rule": "path.forbidden-form",
      "variants": ["posix-absolute", "windows-absolute", "unc", "device", "ads", "uri"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "X03",
      "phase": "T006",
      "rule": "path.link-forbidden",
      "variants": ["symlink", "junction"],
      "platforms": "POSIX_AND_WINDOWS",
      "mode": "native"
    },
    {
      "id": "X04",
      "phase": "T006",
      "rule": "path.resolved-escape",
      "variants": ["canonical-divergence-outside-root"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "X05",
      "phase": "T006",
      "rule": "path.not-regular-file",
      "variants": ["directory"],
      "platforms": "ALL",
      "mode": "native"
    },
    {
      "id": "L01",
      "phase": "T006",
      "variants": [
        "artifact-bytes",
        "depth",
        "reference-count",
        "edge-count",
        "line-bytes",
        "trace-bytes",
        "event-count",
        "dense-short-records",
        "line-before-event-count"
      ],
      "platforms": "ALL",
      "mode": "generated",
      "rules": [
        "limit.artifact-bytes",
        "limit.depth",
        "limit.reference-count",
        "limit.edge-count",
        "limit.line-bytes",
        "limit.trace-bytes",
        "limit.event-count"
      ]
    },
    {
      "id": "L02",
      "phase": "T008",
      "variants": ["descriptor-size-plus-growth-byte"],
      "platforms": "ALL",
      "mode": "behavior"
    },
    {
      "id": "DG01",
      "phase": "T006",
      "variants": ["sort", "deduplicate"],
      "platforms": "ALL",
      "mode": "behavior"
    },
    {
      "id": "DG02",
      "phase": "T006",
      "variants": ["control-character", "absolute-host-path"],
      "platforms": "ALL",
      "mode": "behavior"
    },
    {
      "id": "DG03",
      "phase": "T006",
      "rule": "io.safe-failure",
      "variants": ["invalid-input-exit-2", "safe-io-exit-4"],
      "platforms": "ALL",
      "mode": "behavior"
    },
    {
      "id": "PM01",
      "phase": "T006",
      "variants": [
        "missing-list",
        "unknown-kind",
        "exceeds-ceiling",
        "self-grant",
        "self-attested-trust"
      ],
      "platforms": "ALL",
      "mode": "generated",
      "rules": [
        "permission.required",
        "permission.unknown",
        "permission.exceeds-ceiling",
        "permission.self-grant-forbidden"
      ]
    },
    {
      "id": "PR01",
      "phase": "T005",
      "rule": "privacy.forbidden-content",
      "variants": ["prompt", "chat", "environment", "command-output", "secret", "inline-config"],
      "platforms": "ALL",
      "mode": "generated"
    },
    {
      "id": "PR03",
      "phase": "T008",
      "rule": "privacy.secret-pattern",
      "variants": [
        "trace-artifact",
        "run-id",
        "correlation-id",
        "attempt-id",
        "attempt-work-packet",
        "attempt-retry-of",
        "outcome-work-packet",
        "outcome-attempt-id",
        "evidence-id",
        "evidence-ref",
        "positive-negative-patterns",
        "aggregate-warning",
        "diagnostic-artifact"
      ],
      "platforms": "ALL",
      "mode": "generated"
    }
  ],
  "deferredNativeBoundary": [
    {
      "id": "X06",
      "boundary": "opaque-same-path-windows-reparse-metadata",
      "reason": "The approved pure Node kernel detects canonical divergence but cannot create or inspect every opaque same-path Windows reparse attribute without a native extension."
    },
    {
      "id": "X07",
      "boundary": "descriptor-relative-initialization-race-windows",
      "reason": "Pure Node can verify identities and canonical containment at explicit boundaries but cannot atomically bind directory creation to first identity capture or final identity checks to pathname removal; categorical protection against malicious replacement in those windows requires a reviewed native adapter."
    }
  ],
  "laterHardening": [
    "numeric-domain-overflow",
    "unicode-confusables",
    "filesystem-aliases",
    "deep-lineage",
    "aggregate-project-bytes",
    "randomized-diagnostic-order",
    "encoded-secret-patterns"
  ],
  "atLimitControls": {
    "artifactBytes": 1048576,
    "jsonDepth": 64,
    "projectArtifacts": 10000,
    "circuitEdges": 10000,
    "jsonlLineBytes": 262144,
    "traceBytes": 67108864,
    "traceEvents": 100000
  }
}

{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "files": {
    "includes": [
      "src/**",
      "test/**",
      "schemas/**",
      "scripts/run-v9-dogfood.mjs",
      "scripts/run-v10-dogfood.mjs",
      "scripts/run-v11-dogfood.mjs",
      "scripts/run-v12-dogfood.mjs",
      "scripts/run-v12-release-gate.mjs",
      "scripts/check-packed-consumer.mjs",
      "scripts/fixtures/packed-consumer-host.ts",
      "package.json",
      "tsconfig.json",
      "biome.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  }
}

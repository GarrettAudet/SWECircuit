{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GarrettAudet/SWECircuit/schemas/v1alpha1/module.schema.json",
  "title": "SWECircuit Module",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "$ref": "common.schema.json#/$defs/apiVersion"
    },
    "kind": {
      "const": "Module"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/versionedIdentity"
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input",
        "action",
        "output",
        "gate",
        "outcomes",
        "evidence",
        "requiredPermissions",
        "compatibility",
        "stopConditions"
      ],
      "properties": {
        "input": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "$ref": "common.schema.json#/$defs/artifactPort"
          }
        },
        "action": {
          "$ref": "common.schema.json#/$defs/action"
        },
        "output": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "$ref": "common.schema.json#/$defs/artifactPort"
          }
        },
        "gate": {
          "$ref": "common.schema.json#/$defs/gate"
        },
        "outcomes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "contains": {
            "const": "pass"
          },
          "items": {
            "$ref": "common.schema.json#/$defs/workflowOutcome"
          }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "$ref": "common.schema.json#/$defs/evidenceRequirement"
          }
        },
        "compatibility": {
          "$ref": "common.schema.json#/$defs/compatibility"
        },
        "stopConditions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          }
        },
        "requiredPermissions": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "$ref": "common.schema.json#/$defs/permissionRequest"
          }
        }
      }
    }
  }
}

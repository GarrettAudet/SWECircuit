{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GarrettAudet/SWECircuit/schemas/v1alpha1/circuit.schema.json",
  "title": "SWECircuit Circuit",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "$ref": "common.schema.json#/$defs/apiVersion"
    },
    "kind": {
      "const": "Circuit"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/versionedIdentity"
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry",
        "nodes",
        "routes",
        "exits",
        "stopConditions",
        "verification",
        "compatibility"
      ],
      "properties": {
        "entry": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "module"],
            "properties": {
              "id": {
                "$ref": "common.schema.json#/$defs/identifier"
              },
              "module": {
                "$ref": "common.schema.json#/$defs/identifier"
              },
              "owner": {
                "$ref": "common.schema.json#/$defs/identifier"
              },
              "workPacket": {
                "$ref": "common.schema.json#/$defs/identifier"
              }
            }
          }
        },
        "routes": {
          "type": "array",
          "maxItems": 10000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "outcome", "to", "transfers"],
            "properties": {
              "from": {
                "$ref": "common.schema.json#/$defs/identifier"
              },
              "outcome": {
                "$ref": "common.schema.json#/$defs/workflowOutcome"
              },
              "to": {
                "$ref": "common.schema.json#/$defs/identifier"
              },
              "maxTraversals": {
                "type": "integer",
                "minimum": 1,
                "maximum": 10000
              },
              "transfers": {
                "type": "array",
                "minItems": 1,
                "maxItems": 64,
                "uniqueItems": true,
                "items": {
                  "$ref": "common.schema.json#/$defs/artifactTransfer"
                }
              }
            }
          }
        },
        "exits": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10000,
          "uniqueItems": true,
          "items": {
            "$ref": "common.schema.json#/$defs/identifier"
          }
        },
        "joins": {
          "type": "array",
          "maxItems": 10000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["node", "sources", "strategy", "owner"],
            "properties": {
              "node": {
                "$ref": "common.schema.json#/$defs/identifier"
              },
              "sources": {
                "type": "array",
                "minItems": 2,
                "maxItems": 10000,
                "uniqueItems": true,
                "items": {
                  "$ref": "common.schema.json#/$defs/identifier"
                }
              },
              "strategy": {
                "enum": ["all", "any"]
              },
              "owner": {
                "$ref": "common.schema.json#/$defs/identifier"
              }
            }
          }
        },
        "stopConditions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          }
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "$ref": "common.schema.json#/$defs/evidenceRequirement"
          }
        },
        "compatibility": {
          "$ref": "common.schema.json#/$defs/compatibility"
        },
        "fanOuts": {
          "type": "array",
          "maxItems": 10000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "outcome", "branches", "join", "integrationOwner"],
            "properties": {
              "from": {
                "$ref": "common.schema.json#/$defs/identifier"
              },
              "outcome": {
                "$ref": "common.schema.json#/$defs/workflowOutcome"
              },
              "branches": {
                "type": "array",
                "minItems": 2,
                "maxItems": 10000,
                "uniqueItems": true,
                "items": {
                  "$ref": "common.schema.json#/$defs/identifier"
                }
              },
              "join": {
                "$ref": "common.schema.json#/$defs/identifier"
              },
              "integrationOwner": {
                "$ref": "common.schema.json#/$defs/identifier"
              }
            }
          }
        }
      }
    }
  }
}

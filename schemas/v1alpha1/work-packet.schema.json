{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GarrettAudet/SWECircuit/schemas/v1alpha1/work-packet.schema.json",
  "title": "SWECircuit Work Packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "$ref": "common.schema.json#/$defs/apiVersion"
    },
    "kind": {
      "const": "WorkPacket"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/identity"
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal",
        "completionEvidence",
        "nonGoals",
        "source",
        "scope",
        "role",
        "dependencies",
        "context",
        "authority",
        "verification",
        "handoff",
        "stopConditions"
      ],
      "properties": {
        "goal": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "completionEvidence": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "$ref": "common.schema.json#/$defs/evidenceRequirement"
          }
        },
        "nonGoals": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          }
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["featurePackage", "branch", "baselineCommit"],
          "properties": {
            "featurePackage": {
              "$ref": "common.schema.json#/$defs/relativePath"
            },
            "branch": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
            },
            "baselineCommit": {
              "type": "string",
              "pattern": "^[0-9a-f]{7,64}$"
            }
          }
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["include", "exclude", "conflictZones"],
          "properties": {
            "include": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1024,
              "uniqueItems": true,
              "items": {
                "$ref": "common.schema.json#/$defs/relativePath"
              }
            },
            "exclude": {
              "type": "array",
              "maxItems": 1024,
              "uniqueItems": true,
              "items": {
                "$ref": "common.schema.json#/$defs/relativePath"
              }
            },
            "conflictZones": {
              "type": "array",
              "maxItems": 1024,
              "uniqueItems": true,
              "items": {
                "$ref": "common.schema.json#/$defs/relativePath"
              }
            }
          }
        },
        "role": {
          "type": "object",
          "additionalProperties": false,
          "required": ["capability", "owner"],
          "properties": {
            "capability": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            },
            "owner": {
              "$ref": "common.schema.json#/$defs/identifier"
            }
          }
        },
        "dependencies": {
          "type": "array",
          "maxItems": 10000,
          "uniqueItems": true,
          "items": {
            "$ref": "common.schema.json#/$defs/identifier"
          }
        },
        "context": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "$ref": "common.schema.json#/$defs/evidenceRef"
          }
        },
        "authority": {
          "$ref": "common.schema.json#/$defs/authority"
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "$ref": "common.schema.json#/$defs/evidenceRequirement"
          }
        },
        "handoff": {
          "type": "object",
          "additionalProperties": false,
          "required": ["destination", "requiredFields"],
          "properties": {
            "destination": {
              "$ref": "common.schema.json#/$defs/identifier"
            },
            "requiredFields": {
              "type": "array",
              "minItems": 1,
              "maxItems": 9,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "summary",
                  "filesChanged",
                  "filesInspected",
                  "verificationEvidence",
                  "assumptions",
                  "decisions",
                  "risks",
                  "followUps",
                  "memoryUpdates"
                ]
              }
            }
          }
        },
        "stopConditions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          }
        },
        "deadline": {
          "$ref": "common.schema.json#/$defs/timestamp"
        }
      }
    }
  }
}

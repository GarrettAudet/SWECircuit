{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GarrettAudet/SWECircuit/schemas/v1alpha1/run-event.schema.json",
  "title": "SWECircuit Run Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "$ref": "common.schema.json#/$defs/apiVersion"
    },
    "kind": {
      "const": "RunEvent"
    },
    "metadata": {
      "$ref": "#/$defs/eventMetadata"
    },
    "spec": {
      "$ref": "#/$defs/eventSpec"
    }
  },
  "$defs": {
    "eventMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "$ref": "common.schema.json#/$defs/identifier"
        }
      }
    },
    "baseSpec": {
      "type": "object",
      "required": ["type", "eventTypeVersion", "runId", "sequence", "correlationId", "actor"],
      "properties": {
        "type": {
          "enum": [
            "run.started",
            "run.completed",
            "attempt.state",
            "attempt.heartbeat",
            "attempt.cancellation_requested",
            "workflow.outcome",
            "evidence.recorded",
            "handoff.recorded",
            "verification.recorded",
            "review.recorded",
            "memory.updated",
            "merge.recorded"
          ]
        },
        "eventTypeVersion": {
          "const": "1.0.0"
        },
        "runId": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "time": {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        "correlationId": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "causationId": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "links": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": {
            "$ref": "common.schema.json#/$defs/identifier"
          }
        },
        "actor": {
          "$ref": "common.schema.json#/$defs/identifier"
        }
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "number", "workPacket", "state"],
      "properties": {
        "id": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "number": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        },
        "workPacket": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "state": {
          "$ref": "common.schema.json#/$defs/executionState"
        },
        "retryOf": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "deadline": {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        "terminalCode": {
          "enum": [
            "success",
            "execution_failed",
            "verification_failed",
            "review_failed",
            "handoff_failed",
            "integration_failed",
            "cancelled_by_user",
            "cancelled_by_policy",
            "cancelled_by_parent",
            "deadline_exceeded",
            "heartbeat_expired"
          ]
        }
      },
      "oneOf": [
        {
          "properties": {
            "state": {
              "enum": ["queued", "running", "input_required"]
            }
          },
          "not": {
            "type": "object",
            "required": ["terminalCode"],
            "properties": {
              "terminalCode": {}
            }
          },
          "type": "object"
        },
        {
          "required": ["terminalCode"],
          "properties": {
            "state": {
              "const": "completed"
            },
            "terminalCode": {
              "const": "success"
            }
          },
          "type": "object"
        },
        {
          "required": ["terminalCode"],
          "properties": {
            "state": {
              "const": "failed"
            },
            "terminalCode": {
              "enum": [
                "execution_failed",
                "verification_failed",
                "review_failed",
                "handoff_failed",
                "integration_failed"
              ]
            }
          },
          "type": "object"
        },
        {
          "required": ["terminalCode"],
          "properties": {
            "state": {
              "const": "cancelled"
            },
            "terminalCode": {
              "enum": ["cancelled_by_user", "cancelled_by_policy", "cancelled_by_parent"]
            }
          },
          "type": "object"
        },
        {
          "required": ["terminalCode"],
          "properties": {
            "state": {
              "const": "timed_out"
            },
            "terminalCode": {
              "enum": ["deadline_exceeded", "heartbeat_expired"]
            }
          },
          "type": "object"
        }
      ]
    },
    "heartbeat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observedAt", "expectedEverySeconds"],
      "properties": {
        "observedAt": {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        "expectedEverySeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400
        }
      }
    },
    "cancellation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestedBy", "reasonCode"],
      "properties": {
        "requestedBy": {
          "$ref": "common.schema.json#/$defs/identifier"
        },
        "reasonCode": {
          "enum": [
            "user_request",
            "policy",
            "superseded",
            "dependency_failed",
            "parent_cancelled",
            "shutdown"
          ]
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "$ref": "common.schema.json#/$defs/evidenceRef"
      }
    },
    "eventSpec": {
      "oneOf": [
        {
          "allOf": [
            {
              "$ref": "#/$defs/baseSpec"
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "const": "run.started"
                }
              }
            }
          ],
          "unevaluatedProperties": false,
          "type": "object"
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/baseSpec"
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "const": "run.completed"
                }
              }
            }
          ],
          "unevaluatedProperties": false,
          "type": "object"
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/baseSpec"
            },
            {
              "type": "object",
              "required": ["attempt"],
              "properties": {
                "type": {
                  "const": "attempt.state"
                },
                "stage": {
                  "$ref": "common.schema.json#/$defs/workflowStage"
                },
                "attempt": {
                  "$ref": "#/$defs/attempt"
                }
              }
            }
          ],
          "unevaluatedProperties": false,
          "type": "object"
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/baseSpec"
            },
            {
              "type": "object",
              "required": ["attemptId", "heartbeat"],
              "properties": {
                "type": {
                  "const": "attempt.heartbeat"
                },
                "attemptId": {
                  "$ref": "common.schema.json#/$defs/identifier"
                },
                "heartbeat": {
                  "$ref": "#/$defs/heartbeat"
                }
              }
            }
          ],
          "unevaluatedProperties": false,
          "type": "object"
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/baseSpec"
            },
            {
              "type": "object",
              "required": ["attemptId", "cancellation"],
              "properties": {
                "type": {
                  "const": "attempt.cancellation_requested"
                },
                "attemptId": {
                  "$ref": "common.schema.json#/$defs/identifier"
                },
                "cancellation": {
                  "$ref": "#/$defs/cancellation"
                }
              }
            }
          ],
          "unevaluatedProperties": false,
          "type": "object"
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/baseSpec"
            },
            {
              "type": "object",
              "required": ["stage", "outcome"],
              "properties": {
                "type": {
                  "const": "workflow.outcome"
                },
                "stage": {
                  "$ref": "common.schema.json#/$defs/workflowStage"
                },
                "outcome": {
                  "$ref": "common.schema.json#/$defs/workflowOutcome"
                },
                "workPacket": {
                  "$ref": "common.schema.json#/$defs/identifier"
                },
                "attemptId": {
                  "$ref": "common.schema.json#/$defs/identifier"
                }
              }
            }
          ],
          "unevaluatedProperties": false,
          "type": "object"
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/baseSpec"
            },
            {
              "type": "object",
              "required": ["evidence"],
              "properties": {
                "type": {
                  "enum": [
                    "evidence.recorded",
                    "handoff.recorded",
                    "verification.recorded",
                    "review.recorded",
                    "memory.updated",
                    "merge.recorded"
                  ]
                },
                "stage": {
                  "$ref": "common.schema.json#/$defs/workflowStage"
                },
                "workPacket": {
                  "$ref": "common.schema.json#/$defs/identifier"
                },
                "attemptId": {
                  "$ref": "common.schema.json#/$defs/identifier"
                },
                "evidence": {
                  "$ref": "#/$defs/evidence"
                }
              }
            }
          ],
          "unevaluatedProperties": false,
          "type": "object"
        }
      ]
    }
  }
}

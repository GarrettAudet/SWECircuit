{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GarrettAudet/SWECircuit/schemas/v1alpha1/project.schema.json",
  "title": "SWECircuit Project",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "$ref": "common.schema.json#/$defs/apiVersion"
    },
    "kind": {
      "const": "Project"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/identity"
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifacts"],
      "properties": {
        "artifacts": {
          "type": "array",
          "maxItems": 10000,
          "uniqueItems": true,
          "items": {
            "allOf": [
              {
                "$ref": "common.schema.json#/$defs/relativePath"
              },
              {
                "type": "string",
                "pattern": "^swecircuit/(?:modules|circuits|work-packets|adapters)/[A-Za-z0-9._/-]+[.]json$"
              }
            ]
          }
        },
        "defaultCircuit": {
          "$ref": "common.schema.json#/$defs/identifier"
        }
      }
    }
  }
}
